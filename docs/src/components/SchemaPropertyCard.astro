---
interface Props {
    id?: string;
    title: string;
    category?: string;
    kind: string;
    useCase: string;
    defaultSignature?: string;
    methods?: string[];
    constraints?: string[];
    exports?: string[];
}

const {
    id,
    title,
    category,
    kind,
    useCase,
    defaultSignature,
    methods = [],
    constraints = [],
    exports = [],
} = Astro.props;
---

<article class="schema-property-card" id={id}>
    <header class="schema-property-card__header">
        <div class="schema-property-card__heading">
            <div class="schema-property-card__meta">
                {category && <span class="schema-property-card__badge">{category}</span>}
                <span class="schema-property-card__kind">{kind}</span>
            </div>
            <h3 class="schema-property-card__title">
                <a href={id ? `#${id}` : undefined}>{title}</a>
            </h3>
        </div>
        <p class="schema-property-card__use-case">{useCase}</p>
    </header>

    {defaultSignature && (
        <section class="schema-property-card__section">
            <h4>Default Signature</h4>
            <code>{defaultSignature}</code>
        </section>
    )}

    {methods.length > 0 && (
        <section class="schema-property-card__section">
            <h4>Fluent API</h4>
            <ul class="schema-property-card__list">
                {methods.map((method) => <li><code>{method}</code></li>)}
            </ul>
        </section>
    )}

    {constraints.length > 0 && (
        <section class="schema-property-card__section">
            <h4>Key Behaviors</h4>
            <ul class="schema-property-card__list">
                {constraints.map((constraint) => <li>{constraint}</li>)}
            </ul>
        </section>
    )}

    {exports.length > 0 && (
        <section class="schema-property-card__section">
            <h4>Export Notes</h4>
            <ul class="schema-property-card__list">
                {exports.map((item) => <li>{item}</li>)}
            </ul>
        </section>
    )}

    {Astro.slots.has('example') && (
        <section class="schema-property-card__section">
            <h4>Example</h4>
            <div class="schema-property-card__slot">
                <slot name="example" />
            </div>
        </section>
    )}

    {Astro.slots.has('notes') && (
        <section class="schema-property-card__section">
            <h4>Notes</h4>
            <div class="schema-property-card__slot">
                <slot name="notes" />
            </div>
        </section>
    )}
</article>

<style>
    .schema-property-card {
        border: 1px solid var(--sl-color-gray-5);
        border-radius: 1rem;
        padding: 1.1rem 1.15rem;
        background:
            linear-gradient(180deg, color-mix(in srgb, var(--sl-color-bg) 94%, var(--sl-color-accent-high) 6%), var(--sl-color-bg));
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.04);
        margin: 1.2rem 0 1.5rem;
    }

    .schema-property-card__header {
        display: grid;
        gap: 0.6rem;
        margin-bottom: 0.9rem;
    }

    .schema-property-card__heading {
        display: grid;
        gap: 0.45rem;
    }

    .schema-property-card__meta {
        display: flex;
        gap: 0.5rem;
        align-items: center;
        flex-wrap: wrap;
    }

    .schema-property-card__badge {
        display: inline-flex;
        align-items: center;
        padding: 0.2rem 0.55rem;
        border-radius: 999px;
        background: color-mix(in srgb, var(--sl-color-accent-high) 14%, transparent);
        color: var(--sl-color-text-accent);
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.02em;
        text-transform: uppercase;
    }

    .schema-property-card__title {
        margin: 0;
        font-size: 1.3rem;
        line-height: 1.2;
    }

    .schema-property-card__title a {
        color: inherit;
        text-decoration: none;
    }

    .schema-property-card__title a:hover {
        color: var(--sl-color-text-accent);
    }

    .schema-property-card__kind {
        color: var(--sl-color-gray-2);
        font-size: 0.82rem;
        font-weight: 600;
        letter-spacing: 0.02em;
        text-transform: uppercase;
    }

    .schema-property-card__use-case {
        margin: 0;
        color: var(--sl-color-gray-2);
    }

    .schema-property-card__section + .schema-property-card__section {
        margin-top: 0.95rem;
        padding-top: 0.95rem;
        border-top: 1px solid var(--sl-color-gray-6);
    }

    .schema-property-card__section h4 {
        margin: 0 0 0.55rem;
        font-size: 0.88rem;
        letter-spacing: 0.02em;
        text-transform: uppercase;
        color: var(--sl-color-gray-2);
    }

    .schema-property-card__list {
        margin: 0;
        padding-left: 1.15rem;
    }

    .schema-property-card__list li + li {
        margin-top: 0.35rem;
    }

    .schema-property-card__slot :global(pre) {
        margin: 0.5rem 0 0;
    }

    .schema-property-card__slot :global(p:last-child) {
        margin-bottom: 0;
    }
</style>
